# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=123456789012345678
LOGS_CHANNEL_ID=987654321098765432
OWNER_ID=111222333444555

# Mention Roles (Optional, comma separated. e.g., 111,222)
DISCORD_ROLES_ID=111111111111,222222222222

# Bilibili Configuration (Default is Valorant Mobile CN)
BILIBILI_UID=3546856908917475
CHECK_INTERVAL=300

# Google Gemini AI Configuration
GEMINI_API_KEY=your_google_gemini_api_key_here

# NVIDIA AI Configuration
NVIDIA_API_KEY=nvapi-xxxxxx
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Model prefix priorities (comma-separated, ordered by priority)
# Bot sẽ tự fetch danh sách models khả dụng từ API và lọc theo prefix này
AI_MODEL_PREFIXES=qwen/qwen3.5,google/gemma-3
VISION_MODEL_PREFIXES=google/gemma-3

# Thời gian cache danh sách models (tính theo giờ, default: 1)
MODELS_CACHE_TIME=1

# Fallback models khi API /v1/models không khả dụng (optional)
# AI_MODELS_FALLBACK=google/gemma-3-27b-it
# VISION_MODELS_FALLBACK=google/gemma-3-27b-it

# Environment Mode (debug or release)
ENV_MODE=release